<![CDATA[# ═══════════════════════════════════════════════════════════════════════
# ZEmbeddings — Environment Configuration
# ═══════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values:
#   cp .env.example .env
# ═══════════════════════════════════════════════════════════════════════

# ── OpenAI API (required for API embedding backend) ──────────────────
# Get your key at https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-your-key-here

# ── PostgreSQL / pgvector (optional — only if database.enabled=True) ─
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=zembeddings
# DB_USER=postgres
# DB_PASSWORD=
